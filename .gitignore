# Generated by ./configure or by make at build time -- do not commit.
*.la
*.lo
*.log
*.o
*.trs
.deps/
.dirstamp
.libs/
/config.log
/config.status
/libtool
/Makefile

# autoconf's own scratch cache -- unlike aclocal.m4/configure/
# Makefile.in/m4/*.m4 (all committed so end users never need autoconf/
# automake/libtool installed just to build the library), this is a pure
# rebuild-speed cache with no reason to ever be committed.
/autom4te.cache/

# Generated by `bear -- make`, for clang-tidy -- see .clang-tidy.
/compile_commands.json

# clangd's own index cache, built automatically whenever
# compile_commands.json is present.
/.cache/

# `make tags`/`make TAGS`/`make ctags` output -- automake's own
# generated targets (see also cscope, if that's ever used here).
/TAGS
/tags
/ID
/GTAGS
/GRTAGS
/GSYMS
/GPATH
/cscope.out
/cscope.in.out
/cscope.po.out
/cscope.files

# Build artifacts (program binaries; the non-recursive top-level
# Makefile places these directly at the repo root)
/docs/
/environ
/memo
/netifs
/robinhood.pc
/scan
/tester
/wordfreq
tester-sanitize
tester-sanitize.dSYM/

# Editor backup files
*~
.claude/
\#*
CLAUDE.md
prompts.txt
sessions/
sessions/000001/
sessions/000002/
