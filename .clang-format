# clang-format config for robinhood, tuned against STYLE.md and wired
# into `make format`. See STYLE.md for the authoritative, human-readable
# convention; this is the mechanical subset of it clang-format enforces.
#
# One accepted characteristic, not a gap: a wrapped multi-parameter
# signature collapses back onto one line whenever it fits under
# ColumnLimit (see STYLE.md's "Function declarations and definitions"
# -- this is the actual convention now, not something being avoided).

Language: Cpp
BasedOnStyle: LLVM

ColumnLimit: 78
IndentWidth: 4
UseTab: Never

BreakBeforeBraces: Allman

PointerAlignment: Left
DerivePointerAlignment: false

AlignConsecutiveDeclarations:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
  AlignFunctionDeclarations: true
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
AlignConsecutiveMacros:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false

BreakAfterReturnType: All
BinPackParameters: false
AlignAfterOpenBracket: Align

SpaceBeforeParens: ControlStatements

SpaceBeforeSquareBrackets: false

SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^".*"'
    Priority: 1
  - Regex: '^<.*/.*>'
    Priority: 3
  - Regex: '^<.*>'
    Priority: 2
